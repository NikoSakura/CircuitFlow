# LLM API Keys
KCAD_OPENAI_API_KEY=sk-...
KCAD_ANTHROPIC_API_KEY=sk-ant-...
KCAD_DEEPSEEK_API_KEY=sk-...

# Ollama (local, no key needed)
KCAD_OLLAMA_BASE_URL=http://localhost:11434

# LLM model selection (format: provider:model)
KCAD_PLACEMENT_LLM_SPEC=openai:gpt-4o-mini
KCAD_ROUTING_LLM_SPEC=openai:gpt-4o-mini

# Token budget per run
KCAD_TOKEN_BUDGET_PER_RUN=10000

# KiCad paths (auto-detected if empty)
KCAD_KICAD_FOOTPRINT_DIRS=
